{
  "tasks": {
    "dev": "deno run -A npm:@rsbuild/core/rsbuild dev",
    "build": "deno run -A npm:@rsbuild/core/rsbuild build",
    "download": "deno run -A scripts/download-data.ts"
  },
  "imports": {
    "@std/dotenv": "jsr:@std/dotenv@^0.225.7",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "react": "npm:react@^18.3.1",
    "@types/react": "npm:@types/react@^18.3.31",
    "react-dom": "npm:react-dom@^18.3.1",
    "react-dom/client": "npm:react-dom@^18.3.1/client",
    "@types/react-dom": "npm:@types/react-dom@^18.3.7",
    "@mantine/core": "npm:@mantine/core@^7.17.8",
    "@mantine/hooks": "npm:@mantine/hooks@^7.17.8",
    "@tabler/icons-react": "npm:@tabler/icons-react@^3.44.0",
    "@rsbuild/core": "npm:@rsbuild/core@2.0.15",
    "@rsbuild/plugin-react": "npm:@rsbuild/plugin-react@2.1.0",
    "zod": "npm:zod@^3.25.76",
    "d3": "npm:d3@^7.9.0",
    "leaflet": "npm:leaflet@^1.9.4",
    "@types/leaflet": "npm:@types/leaflet@^1.9.21",
    "leaflet/dist/leaflet.css": "npm:leaflet@^1.9.4/dist/leaflet.css",
    "react-leaflet": "npm:react-leaflet@^4.2.1"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"]
  },
  "nodeModulesDir": "auto",
  "deploy": {
    "org": "vlcdn",
    "app": "parkruns",
    "exclude": [
      "!dist"
    ]
  }
}
